@{
    ViewBag.Title = "Đặt lại mật khẩu";
    var resetEmail = (string?)ViewBag.ResetEmail ?? string.Empty;
    var resetOtp = (string?)ViewBag.ResetOtp ?? string.Empty;
}

<div class="container-fluid bg-secondary mb-5">
    <div class="d-flex flex-column align-items-center justify-content-center" style="min-height: 260px">
        <h1 class="font-weight-semi-bold text-uppercase mb-3">Đặt Lại Mật Khẩu</h1>
        <div class="d-inline-flex">
            <p class="m-0"><a href="@Url.Action("Index", "Home")">Trang Chủ</a></p>
            <p class="m-0 px-2">-</p>
            <p class="text-danger m-0">Đặt lại mật khẩu</p>
        </div>
    </div>
</div>

<div class="container">
    <div class="p-0">
        <div class="form-modal">
            <div class="form-toggle">
                <button id="reset-toggle" class="active" type="button">Tạo Mật Khẩu Mới</button>
            </div>

            <div id="reset-form-page">
                <form id="resetPasswordPageForm" novalidate autocomplete="off">
                    <input type="hidden" id="ResetPageEmail" name="Email" value="@resetEmail" />
                    <input type="hidden" id="ResetPageOtp" name="Otp" value="@resetOtp" />

                    <input type="email" class="form-control mb-3" value="@resetEmail" readonly />

                    <div class="password-field mb-3">
                        <input type="password"
                               id="ResetPageNewPassword"
                               name="NewPassword"
                               class="form-control"
                               placeholder="Mật khẩu mới"
                               autocomplete="new-password"
                               minlength="8"
                               pattern="(?=.*[a-z])(?=.*[A-Z])(?=.*\d).{8,}"
                               title="Ít nhất 8 ký tự, gồm chữ hoa, chữ thường và số" />
                        <button type="button" class="btn toggle-password-btn" data-target="#ResetPageNewPassword" aria-label="Hiện mật khẩu" title="Hiện mật khẩu">
                            <i class="ri-eye-line"></i>
                        </button>
                    </div>
                    <div class="password-rule-hint">Mật khẩu cần ít nhất 8 ký tự, gồm chữ hoa, chữ thường và số.</div>
                    <ul id="password-strength-checklist" class="password-checklist">
                        <li id="rule-length" class="invalid">Ít nhất 8 ký tự</li>
                        <li id="rule-upper" class="invalid">Có ít nhất 1 chữ in hoa</li>
                        <li id="rule-lower" class="invalid">Có ít nhất 1 chữ in thường</li>
                        <li id="rule-digit" class="invalid">Có ít nhất 1 chữ số</li>
                    </ul>

                    <div class="password-field mb-3">
                        <input type="password"
                               id="ResetPageConfirmPassword"
                               name="ConfirmPassword"
                               class="form-control"
                               placeholder="Xác nhận mật khẩu mới"
                               autocomplete="new-password"
                               minlength="8"
                               pattern="(?=.*[a-z])(?=.*[A-Z])(?=.*\d).{8,}"
                               title="Ít nhất 8 ký tự, gồm chữ hoa, chữ thường và số" />
                        <button type="button" class="btn toggle-password-btn" data-target="#ResetPageConfirmPassword" aria-label="Hiện mật khẩu" title="Hiện mật khẩu">
                            <i class="ri-eye-line"></i>
                        </button>
                    </div>

                    <div id="reset-page-message"></div>
                    <button type="submit" class="btn signup">Đặt lại mật khẩu</button>
                    <button type="button" class="btn login mt-2" onclick="window.location.href='@Url.Action("Login", "UserAuth")'">Quay lại đăng nhập</button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    #reset-toggle {
        width: 100%;
        background-color: #4a6cf7;
        color: #fff;
    }

    #reset-form-page .btn {
        width: 100%;
    }

    .password-field {
        position: relative;
    }

    .password-field .form-control {
        padding-right: 46px;
    }

    .toggle-password-btn {
        position: absolute !important;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        border: none !important;
        background: transparent !important;
        box-shadow: none !important;
        min-width: auto !important;
        width: auto !important;
        height: auto !important;
        padding: 0 !important;
        margin: 0 !important;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #5f6b7a;
        font-size: 18px;
        line-height: 1;
        z-index: 5;
    }

    .toggle-password-btn.active {
        color: #3a79ff;
    }

    .password-rule-hint {
        font-size: 13px;
        color: #5f6b7a;
        margin: -4px 0 12px;
    }

    .password-checklist {
        margin: -6px 0 14px;
        padding-left: 18px;
        font-size: 13px;
        line-height: 1.5;
    }

    .password-checklist li {
        color: #8a94a6;
    }

    .password-checklist li.valid {
        color: #239b56;
        font-weight: 600;
    }

    .password-checklist li.invalid {
        color: #8a94a6;
    }
</style>
