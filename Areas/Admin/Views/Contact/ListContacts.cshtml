@model IEnumerable<LapTopBD.Models.ContactRequest>

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý liên hệ";
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Quản lý liên hệ</h2>
        <span class="badge bg-primary">@Model.Count() liên hệ</span>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-striped align-middle contact-table">
            <thead>
                <tr>
                    <th class="col-id">ID</th>
                    <th class="col-name">Họ và tên</th>
                    <th class="col-email">Email</th>
                    <th class="col-phone">Số điện thoại</th>
                    <th class="col-message">Nội dung</th>
                    <th class="col-status">Trạng thái</th>
                    <th class="col-created">Ngày gửi</th>
                    <th class="col-actions">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var contact in Model)
                {
                    <tr class="@(contact.IsRead ? string.Empty : "table-warning")">
                        <td class="col-id text-center">@contact.Id</td>
                        <td class="col-name">@contact.FullName</td>
                        <td class="col-email">@contact.Email</td>
                        <td class="col-phone text-nowrap">@contact.PhoneNumber</td>
                        <td class="col-message">
                            <div class="contact-message-wrap">
                                <div class="contact-message-text" title="@contact.Message">@contact.Message</div>
                                <button type="button" class="btn btn-link btn-sm p-0 contact-message-toggle" aria-label="Xem thêm nội dung" aria-expanded="false">
                                    <i class="fa fa-chevron-down"></i>
                                </button>
                            </div>
                        </td>
                        <td class="col-status text-center">
                            @if (contact.IsRead)
                            {
                                <span class="badge bg-success">Đã xử lý</span>
                                if (contact.ReadAt.HasValue)
                                {
                                    <div class="small text-muted mt-1">@contact.ReadAt.Value.ToString("dd/MM HH:mm")</div>
                                }
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Mới</span>
                            }
                        </td>
                        <td class="col-created text-nowrap">@contact.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="col-actions">
                            <div class="d-flex gap-2 flex-wrap">
                                @if (!contact.IsRead)
                                {
                                    <button type="button" class="btn btn-sm btn-success mark-read-btn" data-id="@contact.Id">Đánh dấu đã xử lý</button>
                                }
                                <button type="button" class="btn btn-sm btn-danger delete-contact-btn" data-id="@contact.Id">Xóa</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div id="message" class="mt-3"></div>
</div>

<style>
    .contact-table {
        table-layout: fixed;
        width: 100%;
    }

    .contact-table .col-id {
        width: 70px;
    }

    .contact-table .col-name {
        min-width: 160px;
    }

    .contact-table .col-email {
        min-width: 230px;
        word-break: break-word;
    }

    .contact-table .col-phone {
        min-width: 130px;
    }

    .contact-table .col-message {
        width: 320px;
        max-width: 320px;
    }

    .contact-message-wrap {
        display: flex;
        align-items: flex-start;
        gap: 6px;
        width: 100%;
    }

    .contact-message-text {
        flex: 1 1 auto;
        min-width: 0;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
        overflow: hidden;
        white-space: normal;
        word-break: break-word;
        overflow-wrap: anywhere;
        line-height: 1.4;
        max-height: 2.8em;
    }

    .contact-message-wrap.is-expanded .contact-message-text {
        display: block;
        -webkit-line-clamp: unset;
        max-height: none;
        overflow: visible;
    }

    .contact-message-toggle {
        flex: 0 0 auto;
        color: #0d6efd;
        text-decoration: none;
        line-height: 1;
        box-shadow: none;
    }

    .contact-message-toggle:hover,
    .contact-message-toggle:focus {
        text-decoration: none;
        box-shadow: none;
    }

    .contact-message-toggle.is-hidden {
        display: none;
    }

    .contact-message-wrap.is-expanded .contact-message-toggle i {
        transform: rotate(180deg);
    }

    .contact-message-toggle i {
        transition: transform 0.15s ease-in-out;
    }

    .contact-table .col-status {
        width: 130px;
    }

    .contact-table .col-created {
        width: 160px;
    }

    .contact-table .col-actions {
        min-width: 180px;
    }
</style>

@section Scripts {
    <script>
        function syncContactMessageToggles() {
            $(".contact-message-wrap").each(function () {
                var $wrap = $(this);
                var $text = $wrap.find(".contact-message-text");
                var $toggle = $wrap.find(".contact-message-toggle");

                if ($text[0] && $toggle.length) {
                    // Force reflow to get accurate scrollHeight
                    var scrollHeight = $text[0].scrollHeight;
                    var clientHeight = $text[0].clientHeight;
                    var isOverflowing = scrollHeight > clientHeight + 2;
                    
                    // Show toggle if content overflows
                    if (isOverflowing) {
                        $toggle.removeClass("is-hidden");
                    } else {
                        $toggle.addClass("is-hidden");
                    }
                }
            });
        }

        $(document).on("click", ".contact-message-toggle", function (e) {
            e.preventDefault();
            var $wrap = $(this).closest(".contact-message-wrap");
            var isExpanded = $wrap.hasClass("is-expanded");

            $wrap.toggleClass("is-expanded", !isExpanded);
            $(this).attr("aria-expanded", String(!isExpanded));
        });

        $(document).on("click", ".mark-read-btn", function () {
            var id = $(this).data("id");
            $.post("@Url.Action("MarkRead", "Contact", new { area = "Admin" })", { id: id })
                .done(function (response) {
                    if (response.success) {
                        location.reload();
                    } else {
                        $("#message").html('<div class="alert alert-danger">' + response.message + '</div>');
                    }
                })
                .fail(function () {
                    $("#message").html('<div class="alert alert-danger">Không thể cập nhật trạng thái liên hệ.</div>');
                });
        });

        $(document).on("click", ".delete-contact-btn", function () {
            if (!confirm("Bạn có chắc muốn xóa liên hệ này không?")) {
                return;
            }

            var id = $(this).data("id");
            $.post("@Url.Action("DeleteContact", "Contact", new { area = "Admin" })", { id: id })
                .done(function (response) {
                    if (response.success) {
                        location.reload();
                    } else {
                        $("#message").html('<div class="alert alert-danger">' + response.message + '</div>');
                    }
                })
                .fail(function () {
                    $("#message").html('<div class="alert alert-danger">Không thể xóa liên hệ.</div>');
                });
        });

        $(function () {
            syncContactMessageToggles();
        });
    </script>
}