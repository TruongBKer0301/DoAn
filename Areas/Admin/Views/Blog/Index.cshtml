@model IEnumerable<LapTopBD.Models.BlogPost>
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Danh sách blog";
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">Danh sách bài viết blog</h4>
            <a class="btn btn-primary" asp-area="Admin" asp-controller="Blog" asp-action="Create">Tạo bài viết</a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <div class="card">
            <div class="card-body table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th style="width: 60px;">ID</th>
                            <th>Tiêu đề</th>
                            <th style="width: 170px;">Trạng thái</th>
                            <th style="width: 220px;">Ngày tạo</th>
                            <th style="width: 220px;">Tác giả</th>
                            <th style="width: 180px;" class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted">Chưa có bài viết nào.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var post in Model)
                            {
                                <tr>
                                    <td>@post.Id</td>
                                    <td>
                                        <div class="fw-semibold">@post.Title</div>
                                        <small class="text-muted">@post.Slug</small>
                                    </td>
                                    <td>
                                        @if (post.IsPublished)
                                        {
                                            <span class="badge bg-success">Đã đăng</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Bản nháp</span>
                                        }
                                    </td>
                                    <td>@post.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@(post.Admin?.FullName ?? "Không rõ")</td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-primary" asp-area="Admin" asp-controller="Blog" asp-action="Edit" asp-route-id="@post.Id">Sửa</a>
                                        <form asp-area="Admin" asp-controller="Blog" asp-action="Delete" asp-route-id="@post.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa bài viết này?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
