@model IEnumerable<LapTopBD.Models.ViewModels.Admin.OrderViewModel>

@{
    ViewData["Title"] = "Danh sách đơn hàng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <h2 class="text-center mb-4">Danh sách đơn hàng</h2>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-bordered table-striped align-middle order-table">
                <thead>
                    <tr>
                        <th class="col-id">ID</th>
                        <th class="col-customer">Tên khách hàng</th>
                        <th class="col-product">Sản phẩm</th>
                        <th class="col-qty">Số lượng</th>
                        <th class="col-date">Ngày đặt hàng</th>
                        <th class="col-status">Trạng thái</th>
                        <th class="col-total">Tổng giá</th>
                        <th class="col-actions">Thao tác</th>
                        <th class="col-address">Địa chỉ</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td class="col-id text-center">@order.Id</td>
                            <td class="col-customer">@order.UserName</td>
                            <td class="col-product">@order.ProductName</td>
                            <td class="col-qty text-center">@order.Quantity</td>
                            <td class="col-date text-nowrap">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="col-status text-center">
                                <span class="badge @(order.OrderStatus == "Pending" ? "bg-warning text-dark" : order.OrderStatus == "Paid" ? "bg-info" : order.OrderStatus == "Shipping" ? "bg-info" : order.OrderStatus == "Delivered" ? "bg-success" : "bg-danger")">
                                    @order.OrderStatus
                                </span>
                            </td>
                            <td class="col-total text-nowrap">@order.TotalPrice.ToString("N0") VNĐ</td>
                            <td class="col-actions">
                                <select class="form-control form-control-sm update-status" data-order-id="@order.Id" data-current-status="@order.OrderStatus">
                                    <option value="Pending" selected="@(order.OrderStatus == "Pending" ? "selected" : null)">Pending</option>
                                    <option value="Paid" selected="@(order.OrderStatus == "Paid" ? "selected" : null)">Paid</option>
                                    <option value="Shipping" selected="@(order.OrderStatus == "Shipping" ? "selected" : null)">Shipping</option>
                                    <option value="Delivered" selected="@(order.OrderStatus == "Delivered" ? "selected" : null)">Delivered</option>
                                    <option value="Cancelled" selected="@(order.OrderStatus == "Cancelled" ? "selected" : null)">Cancelled</option>
                                </select>
                            </td>
                            <td class="col-address">@order.FullAddress</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-center">Không có đơn hàng nào.</p>
    }

    <div id="message" class="mt-3"></div>
</div>

<style>
    .order-table .col-id {
        width: 70px;
    }

    .order-table .col-customer {
        min-width: 180px;
    }

    .order-table .col-product {
        min-width: 220px;
        max-width: 320px;
        word-break: break-word;
    }

    .order-table .col-qty {
        width: 100px;
    }

    .order-table .col-date {
        width: 165px;
    }

    .order-table .col-status {
        width: 120px;
    }

    .order-table .col-total {
        width: 150px;
    }

    .order-table .col-actions {
        min-width: 150px;
    }

    .order-table .col-address {
        min-width: 260px;
        max-width: 380px;
        white-space: normal;
        word-break: break-word;
    }
</style>
