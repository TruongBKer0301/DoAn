@model LapTopBD.ViewModels.AdminViewModel

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Chỉnh sửa Admin";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-8 col-md-10 col-sm-12 mx-auto">
            <h2 class="text-center mb-4">Chỉnh sửa Admin</h2>

            <form id="editAdminForm">
                <input type="hidden" asp-for="Id" />
                <div class="form-group avatar-upload-container">
                    <label for="AvatarFile">Ảnh đại diện</label>
                    <div class="upload-box" id="editAdminAvatarDropZone">
                        <input type="file" class="form-control-file avatar-input" id="AvatarFile" name="AvatarFile" accept=".jpg, .jpeg, .png">
                        <span class="upload-instruction">
                            <i class="ri-image-add-fill"></i>
                        </span>
                        <img id="avatarPreview" src="@(Model.Avatar ?? "/images/default-avatar.png")" class="img-preview">
                    </div>
                </div>

                <div class="form-group">
                    <label for="Username">Tên đăng nhập</label>
                    <input asp-for="Username" class="form-control" id="Username" required />
                </div>

                <div class="form-group">
                    <label for="FullName">Họ và Tên</label>
                    <input asp-for="FullName" class="form-control" id="FullName" required />
                </div>

                <div class="form-group">
                    <label for="Roles">Chức vụ</label>
                    <input asp-for="Roles" class="form-control" id="Roles" required />
                </div>

                <div class="form-group">
                    <label for="Status">Trạng thái</label>
                    <select asp-for="Status" class="form-control" id="Status" required>
                        <option value="Hoạt động">Hoạt động</option>
                        <option value="Không hoạt động">Không hoạt động</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="CreationDate">Ngày tạo</label>
                    <input asp-for="CreationDate" type="date" class="form-control" id="CreationDate" required />
                </div>

                <div class="form-group">
                    <label for="OldPassword">Mật khẩu cũ</label>
                    <input type="password" class="form-control" id="OldPassword" name="OldPassword" />
                </div>

                <div class="form-group">
                    <label for="NewPassword">Mật khẩu mới</label>
                    <input type="password" class="form-control" id="NewPassword" name="NewPassword" />
                </div>

                <div class=" mt-3 d-flex justify-content-between">
                    <button type="button" id="saveAdminBtn" class="btn btn-primary btn-block">Lưu</button>
                    <a asp-action="ListAdmins" class="btn btn-secondary btn-block">Hủy</a>
                </div>

                <div id="message" class="mt-3"></div>
            </form>
        </div>
    </div>
</div>

<script>
    (function () {
        const dropZone = document.getElementById('editAdminAvatarDropZone');
        const input = document.getElementById('AvatarFile');
        const preview = document.getElementById('avatarPreview');
        const hint = dropZone ? dropZone.querySelector('.upload-instruction') : null;

        if (!dropZone || !input || !preview) {
            return;
        }

        const showPreview = (file) => {
            if (!file || !file.type.startsWith('image/')) {
                return;
            }

            const reader = new FileReader();
            reader.onload = function (e) {
                preview.src = e.target?.result || preview.src;
                preview.style.display = 'block';
                preview.classList.remove('d-none');
                if (hint) {
                    hint.style.display = 'none';
                }
            };

            reader.readAsDataURL(file);
        };

        const setInputFile = (file) => {
            try {
                const transfer = new DataTransfer();
                transfer.items.add(file);
                input.files = transfer.files;
            } catch {
                input._droppedFile = file;
            }
        };

        ['dragenter', 'dragover'].forEach((eventName) => {
            dropZone.addEventListener(eventName, (e) => {
                e.preventDefault();
                e.stopPropagation();
                dropZone.classList.add('drag-over');
            });
        });

        ['dragleave', 'dragend', 'drop'].forEach((eventName) => {
            dropZone.addEventListener(eventName, (e) => {
                e.preventDefault();
                e.stopPropagation();
                dropZone.classList.remove('drag-over');
            });
        });

        dropZone.addEventListener('drop', (e) => {
            const files = Array.from(e.dataTransfer?.files || []).filter(f => f.type.startsWith('image/'));
            if (files.length === 0) {
                return;
            }

            setInputFile(files[0]);
            showPreview(files[0]);
        });

        input.addEventListener('change', function () {
            if (input.files && input.files.length > 0) {
                input._droppedFile = null;
                showPreview(input.files[0]);
            } else if (input._droppedFile) {
                showPreview(input._droppedFile);
            }
        });
    })();
</script>